---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const guide = messages.guide;
const guideImgs = [
  '/gallery/chiang-rai-night-bazaar-2.jpg',
  '/gallery/chiang-rai-night-bazaar-3.jpg',
];
---

<section id="guide" class="py-20 bg-ivory text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{guide.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{guide.heading}</h2>
    <p class="mt-4 max-w-2xl text-ink/80">{guide.lead}</p>

    <!-- Anti Scam Tip -->
    {guide.scamTip && (
      <div class="mt-8 rounded-xl bg-red-50 border border-red-200 p-5 max-w-4xl shadow-sm">
        <h3 class="font-display text-red-700 text-lg font-semibold flex items-center gap-2">
          {guide.scamTip.tag}
        </h3>
        <p class="mt-2 text-red-900/80 text-sm leading-relaxed">
          {guide.scamTip.text}
        </p>
      </div>
    )}

    <div class="grid md:grid-cols-3 gap-6 mt-10">
      <!-- hours -->
      <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
        <span class="font-display text-gold text-2xl">{guide.hours.tag}</span>
        <h3 class="font-display text-xl text-teak mt-1 mb-3">{guide.hours.title}</h3>
        <p class="font-semibold text-teak">{guide.hours.time}</p>
        <ul class="mt-3 space-y-2 text-sm text-ink/75">
          {guide.hours.items.map((it) => (
            <li class="flex justify-between gap-3 border-b border-gold/15 pb-2">
              <span>{it.label}</span><span class="text-teak font-medium whitespace-nowrap">{it.value}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- fees -->
      <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
        <span class="font-display text-gold text-2xl">{guide.fees.tag}</span>
        <h3 class="font-display text-xl text-teak mt-1 mb-3">{guide.fees.title}</h3>
        <ul class="space-y-3 text-sm">
          {guide.fees.items.map((it) => (
            <li>
              <div class="font-semibold text-teak">{it.title}</div>
              <div class="text-ink/70">{it.desc}</div>
            </li>
          ))}
        </ul>
      </div>

      <!-- transport -->
      <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
        <span class="font-display text-gold text-2xl">{guide.transport.tag}</span>
        <h3 class="font-display text-xl text-teak mt-1 mb-3">{guide.transport.title}</h3>
        <ul class="space-y-3 text-sm">
          {guide.transport.items.map((it) => (
            <li>
              <div class="font-semibold text-teak">{it.title}</div>
              <div class="text-ink/70">{it.desc}</div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
