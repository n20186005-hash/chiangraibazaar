---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const nb = messages.nearby;
---

<section id="nearby" class="py-20 bg-ivory text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{nb.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{nb.heading}</h2>
    <p class="mt-4 max-w-3xl text-ink/85 text-lg">{nb.lead}</p>

    <div class="grid md:grid-cols-2 gap-6 mt-10">
      {nb.items.map((it) => (
        <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
          <span class="font-hand text-gold text-2xl">📍</span>
          <h3 class="font-display text-xl text-teak mt-2">{it.title}</h3>
          <p class="mt-2 text-ink/75">{it.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
