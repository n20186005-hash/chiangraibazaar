---
import '../styles/global.css';
import { siteConfig } from '../config';
import { htmlLang, languagesList, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
}
const { lang, title, description } = Astro.props;
const canonical = `${siteConfig.domain}/${lang}/`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TouristAttraction',
    name: siteConfig.name[lang],
    description,
    image: `${siteConfig.domain}/gallery/chiang-rai-night-bazaar-1.jpg`,
    url: canonical,
    address: {
      '@type': 'PostalAddress',
      streetAddress: siteConfig.address[lang],
      addressCountry: 'TH',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: siteConfig.coords.lat,
      longitude: siteConfig.coords.lng,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: siteConfig.rating,
      reviewCount: siteConfig.reviewCount.replace(/,/g, ''),
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
        opens: '18:00',
        closes: '23:00',
      },
    ],
    sameAs: siteConfig.sameAs,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What are the opening hours?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The night bazaar is open every day from 18:00 to 23:00.'
        }
      },
      {
        '@type': 'Question',
        name: 'How do I get there?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'It sits in central Chiang Rai on Phahon Yothin Road, a 10–15 minute walk from the Old City gate or the Golden Clock Tower. Red songthaews and Grab also serve the area.'
        }
      }
    ]
  }
];
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href={`/gallery/chiang-rai-night-bazaar-1.jpg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={htmlLang[lang]} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteConfig.domain}/gallery/chiang-rai-night-bazaar-1.jpg`} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    {languagesList.map((l) => (
      <link rel="alternate" hreflang={htmlLang[l]} href={`${siteConfig.domain}/${l}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteConfig.domain}/th/`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Trirong:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Sarabun:wght@300;400;500;600;700&family=Charm:wght@400;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="grain">
    <slot />
  </body>
</html>
